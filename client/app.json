{
  "expo": {
    "name": "rstify",
    "slug": "rstify",
    "scheme": "rstify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1B26"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cc.js-node.rstify"
    },
    "android": {
      "package": "cc.js_node.rstify",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8E8E8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4F46E5"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "16c32c5a-8e04-4958-a55b-5868a1c337eb"
      }
    },
    "owner": "jsprague"
  }
}
