# rstify Server Configuration
# Copy to .env and adjust values for your deployment

# ─── Server ──────────────────────────────────────────────
# Address and port to bind the HTTP server
LISTEN_ADDR=0.0.0.0:8080

# SQLite database path
DATABASE_URL=sqlite://rstify.db

# JWT signing secret (MUST change in production, >=32 bytes recommended)
# Generate one: openssl rand -base64 64
JWT_SECRET=change-me-in-production

# Directory for uploaded files (icons, attachments)
UPLOAD_DIR=./uploads

# Max attachment upload size in bytes (default: 25 MiB)
# RSTIFY_MAX_ATTACHMENT_SIZE=26214400

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# ─── CORS ────────────────────────────────────────────────
# Comma-separated allowed origins (defaults to same-origin only if unset)
# CORS_ORIGINS=https://your-domain.com

# ─── Rate Limiting ──────────────────────────────────────
# Token bucket burst capacity per client
RATE_LIMIT_BURST=60
# Token refill rate per second
RATE_LIMIT_RPS=10
# Trust X-Forwarded-For for rate-limit keying. Set to true ONLY when a trusted
# reverse proxy fronts the server (Traefik/nginx/Caddy); otherwise clients can
# spoof the header. Behind Traefik you WANT this true, or all users collapse into
# the proxy's single shared bucket.
# RATE_LIMIT_TRUST_PROXY=true

# ─── Outbound Webhook SSRF Policy ───────────────────────
# Allow outgoing webhooks and X-Attach fetches to reach private/LAN/reserved
# addresses (e.g. a same-host or docker-network automation endpoint). Off by
# default (SSRF-safe). Enable only on a trusted single-user instance.
# WEBHOOK_ALLOW_PRIVATE_TARGETS=true

# ─── FCM Push Notifications (optional) ──────────────────
# Both must be set to enable Firebase Cloud Messaging
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── SMTP Email Notifications (optional) ────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=rstify@example.com
